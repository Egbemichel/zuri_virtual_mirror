# Security + caching headers, shipped inside the build artifact so they apply on
# every Netlify deploy (CLI or native). See DEPLOYMENT.md for rationale.
#
# We deliberately do NOT set Cross-Origin-Embedder-Policy: it would block the
# jsDelivr MediaPipe loader scripts. MediaPipe Face Mesh is single-threaded and
# needs no cross-origin isolation.
#
# script-src MUST keep 'unsafe-eval': MediaPipe's Emscripten/WASM glue compiles
# code via eval()/new Function(). 'wasm-unsafe-eval' alone is insufficient and
# the camera tracking will fail with a CSP "Refused to evaluate a string as
# JavaScript" error. This is an accepted trade-off for running MediaPipe.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-eval' 'wasm-unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob:; media-src 'self' blob:; connect-src 'self' https://cdn.jsdelivr.net; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; frame-ancestors 'self'

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/mediapipe/*
  Cache-Control: public, max-age=604800

/index.html
  Cache-Control: no-cache
